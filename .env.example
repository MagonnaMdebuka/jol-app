# Supabase (required for live data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Foursquare Places API (optional - for venue search during owner setup)
VITE_FOURSQUARE_API_KEY=

# Google Places API (optional - fallback when Foursquare returns no results)
VITE_GOOGLE_PLACES_API_KEY=

# OSM Seeding Script (server-side only, not VITE_ prefixed)
# Used by: npm run seed:osm
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
